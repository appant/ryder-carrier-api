# ============================================================================
# Ryder API Integration — Environment Variables Template
# Copy to .env and fill in real values for local dev. NEVER commit .env.
# ============================================================================

# --- Environment selector ---
APP_ENV=dev                                          # dev | prod
LOG_LEVEL=INFO                                       # DEBUG | INFO | WARNING | ERROR

# --- Azure Key Vault ---
# Use Managed Identity in Azure (DefaultAzureCredential picks it up automatically).
# For local dev, run `az login` first.
KEY_VAULT_URI=https://kv-ryder-dev.vault.azure.net/

# --- Snowflake connection ---
SNOWFLAKE_AUTH_METHOD=password                       # password | keypair
SNOWFLAKE_ACCOUNT=bj38886.central-us.azure
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=MASTERY_USMMGTEST_MASTERMIND_SHARE
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=RYDER_INTEGRATION_ROLE_DEV
SNOWFLAKE_QUERY_TIMEOUT_SECONDS=60

# Key Vault secret names — code fetches by these names, never the values
SECRET_NAME_SNOWFLAKE_USER=snowflake-user
SECRET_NAME_SNOWFLAKE_PASSWORD=snowflake-password
SECRET_NAME_SNOWFLAKE_PRIVATE_KEY=snowflake-private-key
SECRET_NAME_SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=snowflake-private-key-passphrase

# --- Ryder Carrier API ---
RYDER_API_BASE_URL=https://api.ryder.com/rcsc/events/v1
RYDER_TIMEOUT_SECONDS=30
RYDER_MAX_CONCURRENCY=5
RYDER_MAX_RETRIES=5
SECRET_NAME_RYDER_API_KEY=ryder-api-key
SECRET_NAME_RYDER_SCAC=ryder-carrier-scac

# --- Customer filter ---
RYDER_CUSTOMER_CODES=AMEBOTFRTX,DRPEPPFRTX,KEURIGFRTX,KEUDRPFRTX,MOTTSFRTX

# --- Azure Storage (state) ---
STORAGE_ACCOUNT_NAME=stryderdev
WATERMARK_TABLE_NAME=watermarks
AUDIT_TABLE_NAME=sentaudit

# --- Audit retention ---
AUDIT_RETENTION_DAYS=180

# --- Watermark safety ---
WATERMARK_OVERLAP_MINUTES=5
WATERMARK_MAX_LOOKBACK_HOURS=72

# --- Application Insights (optional locally) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
